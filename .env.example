# Copy to .env and adjust as needed: cp .env.example .env

# Postgres
POSTGRES_USER=pickem
POSTGRES_PASSWORD=pickem
POSTGRES_DB=pickem
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Demo mode — IS_DEMO_DATA (default OFF; PROD-LEAK GUARD)
# -----------------------------------------------------------------------------
# Defaults OFF. When OFF the app runs the PRODUCTION path: the real ESPN
# scoreboard source, no demo code constructed, no fake data seeded — byte-for-byte
# the prod behavior.
#
# When set to true, the migrate step seeds a FAKE, time-shifted 2025 demo season
# (the 2025 fixture positioned so week-1's first kickoff is ~24h out; it then
# unspools in real shifted time via the Celery beat poller), the demo bots' wk1-3
# picks are seeded directly, and every process logs a loud startup banner so the
# demo can never be on silently. This is for local demos ONLY.
#
# NEVER enable this in production. Remove it or leave it false before go-live —
# the demo data is labeled season 2025 and is cleanly purgeable, but the gate is
# the guard that keeps fake data out of the prod path.
IS_DEMO_DATA=false


# -----------------------------------------------------------------------------
# Discord bot — REQUIRED for the `bot` compose service
# -----------------------------------------------------------------------------
# Read via Settings and consumed by backend/app/bot/. The API and worker
# containers leave these unset (extra="ignore" silences them); only the `bot`
# service needs them. The bot provisions accounts on demand (v3.0). Without a
# valid token the bot container cannot start.
#
# DISCORD_BOT_TOKEN: Discord Developer Portal → your application → Bot →
#   Reset Token. Treat as a secret — never commit the real value.
DISCORD_BOT_TOKEN=CHANGE_ME_DISCORD_BOT_TOKEN
# DISCORD_GUILD_ID: the server (guild) snowflake the bot operates in. Enable
#   Discord Developer Mode → right-click the server → Copy Server ID. 64-bit int.
DISCORD_GUILD_ID=CHANGE_ME_DISCORD_GUILD_ID


# -----------------------------------------------------------------------------
# pgAdmin — REQUIRED for the pgadmin compose service
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=root@example.com
PGADMIN_PASSWORD=CHANGE_ME

# Discord notification channels (bot posts app activity here)
DISCORD_CHAT_LOG_CHANNEL=pickem-logger   # admin-visibility granular log feed
DISCORD_CHAT_CHANNEL=pickem-chat         # player-facing chat / milestones feed


# -----------------------------------------------------------------------------
# APP_ENV — deploy environment + fail-closed production guard (260630-lkf)
# -----------------------------------------------------------------------------
# Default: development. Leave unset (or development/test/staging) for local work,
# the demo stack, and CI — the guard below is a strict no-op outside production,
# so every existing path is unaffected.
#
# Set APP_ENV=production on the REAL server. Doing so activates a fail-closed
# startup guard: the process REFUSES TO BOOT (Settings raises at import) unless
# you ALSO provide secure values for all of:
#   - SECRET_KEY            real random string, 32+ chars (NOT the dev default)
#   - SESSION_COOKIE_SECURE=true   (HTTPS-only session cookies)
#   - CORS_ALLOWED_ORIGINS         real non-localhost origin(s) as a JSON array
#                                  (parsed as JSON — a bare/comma-separated value
#                                  CRASHES Settings at import). Use full origins
#                                  with scheme, no trailing slash. Single:
#                                    CORS_ALLOWED_ORIGINS=["https://picks.example.com"]
#                                  Multiple (www is a separate origin):
#                                    CORS_ALLOWED_ORIGINS=["https://picks.example.com","https://www.picks.example.com"]
#                                  In .env consumed by docker compose env_file, do
#                                  NOT wrap the value in outer quotes.
#   - IS_DEMO_DATA=false           (never serve demo data in production)
# The boot error names every check that failed and the env var to set for each.
APP_ENV=development


# -----------------------------------------------------------------------------
# SESSION_COOKIE_NAME — session cookie name (prod: prefer the __Host- prefix)
# -----------------------------------------------------------------------------
# Default: session (fine for local/dev over http).
#
# In PRODUCTION over HTTPS, set SESSION_COOKIE_NAME=__Host-session. The __Host-
# prefix makes the browser ENFORCE that the cookie is Secure, Path=/, and carries
# NO Domain attribute — a free hardening win. It is safe here WITHOUT any code
# change because both cookie setters (app.api.auth._set_session_cookie and
# app.csrf.set_csrf_cookie) already use path="/" and never send a Domain, and the
# logout deletion mirrors those same attributes. Needs SESSION_COOKIE_SECURE=true
# (required in prod anyway) so the cookie is actually sent. Recommended, not
# required — a plain `session` name still boots.
# SESSION_COOKIE_NAME=__Host-session
SESSION_COOKIE_NAME=session
