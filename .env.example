# Copy to .env and adjust as needed: cp .env.example .env

# Postgres
POSTGRES_USER=pickem
POSTGRES_PASSWORD=pickem
POSTGRES_DB=pickem
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Discord bot — REQUIRED for the `bot` compose service
# -----------------------------------------------------------------------------
# Read via Settings and consumed by backend/app/bot/. The API and worker
# containers leave these unset (extra="ignore" silences them); only the `bot`
# service needs them. The bot provisions accounts on demand (v3.0). Without a
# valid token the bot container cannot start.
#
# DISCORD_BOT_TOKEN: Discord Developer Portal → your application → Bot →
#   Reset Token. Treat as a secret — never commit the real value.
DISCORD_BOT_TOKEN=CHANGE_ME_DISCORD_BOT_TOKEN
# DISCORD_GUILD_ID: the server (guild) snowflake the bot operates in. Enable
#   Discord Developer Mode → right-click the server → Copy Server ID. 64-bit int.
DISCORD_GUILD_ID=CHANGE_ME_DISCORD_GUILD_ID


# -----------------------------------------------------------------------------
# pgAdmin — REQUIRED for the pgadmin compose service
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=root@example.com
PGADMIN_PASSWORD=CHANGE_ME
